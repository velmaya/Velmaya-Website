# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (secrets). The example template is safe to track.
.env*
!.env.example

# vercel
.vercel

# cloudflare / opennext
.open-next/
.wrangler/

# typescript
*.tsbuildinfo
next-env.d.ts

# dev logo render artifact
scripts/logo-preview.png

# claude local files
.claude/settings.local.json
.claude/scheduled_tasks.lock

# catalogue source images — staged product photos, not committed (see
# catalogue/README.md). Keep the folder-structure guide files tracked.
catalogue/images/**
!catalogue/images/**/
!catalogue/images/**/README.txt
!catalogue/images/**/.gitkeep
