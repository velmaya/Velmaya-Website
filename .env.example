# Supabase (free tier) — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 — R2 > Manage API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=velmaya-media
# Public URL the bucket serves from (r2.dev dev URL, or a custom domain once set up)
R2_PUBLIC_BASE_URL=

# Razorpay — Settings > API Keys (TEST keys only until the full flow passes)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# Razorpay Dashboard > Webhooks (test mode) — verifies webhook signatures
RAZORPAY_WEBHOOK_SECRET=

# WhatsApp click-to-chat (single source of truth, see docs)
NEXT_PUBLIC_WHATSAPP_NUMBER=919597075752
NEXT_PUBLIC_CONTACT_EMAIL=shop.velmaya@gmail.com
NEXT_PUBLIC_INSTAGRAM_HANDLE=labelvelmaya

# Commerce / shipping (config-driven, not hardcoded — see docs/06 §3a)
# Defaults: free shipping at/above 1499, otherwise a flat 79 fee.
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=1499
NEXT_PUBLIC_SHIPPING_FLAT_FEE=79

# Email notifications (Resend, free tier) — Stage 4
RESEND_API_KEY=
EMAIL_FROM=orders@velmaya.com
SHOP_NOTIFICATION_EMAIL=shop.velmaya@gmail.com

# Cron secret protecting the reservation-expiry sweep endpoint — Stage 3+
CRON_SECRET=

# Optional: point the verify:* scripts at a deployed URL instead of
# localhost:3000 (e.g. when smoke-testing production post-deploy).
# See docs/13-production-deployment-cloudflare.md §13.
VERIFY_BASE_URL=
